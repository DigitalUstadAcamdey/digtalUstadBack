API_KEY=
API_SECRET=
CLOUD_NAME=

BASE_URL=
BUNNY_API_KEY=
VIDEO_LIBRARY_ID=
# admin info
EMAIL=
PASSWORD=
USERNAME=

EMAIL_FROM=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USERNAME=
EMAIL_PASSWORD=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

JWT_EXPIRATION_TIME=
JWT_SECRET=

NODE_ENV=development
NODE_VERSION=22.18.0
PORT=5000
URL=http://localhost:5000
CLIENT_URL=http://localhost:3000
TELEGRAM_BOT_TOKEN=
TELEGRAM_VIP_CHAT_ID=
TELEGRAM_NORMAL_LINK=
TELEGRAM_VIP_LINK_EXPIRY_MINUTES=15

MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
ME_CONFIG_BASICAUTH_ENABLED=true
ME_CONFIG_BASICAUTH_USERNAME=
ME_CONFIG_BASICAUTH_PASSWORD=

# Local development with docker-compose.dev.yml.
# The development MongoDB port is bound to 127.0.0.1 and intentionally has no
# credentials. Do not use this URI or topology for production.
MONGO_REPLICA_SET_NAME=rs0
URI=mongodb://127.0.0.1:27017/e-learning?replicaSet=rs0&directConnection=true
MONGODB_TRANSACTION_TEST_URI=mongodb://127.0.0.1:27017/e-learning-transaction-readiness?replicaSet=rs0&directConnection=true

# When the API itself runs inside the development Compose network:
# URI=mongodb://mongo-dev:27017/e-learning?replicaSet=rs0

# Production must supply its own authenticated URI and topology. Examples:
# URI=mongodb://<mongo-user>:<mongo-password>@mongo:27017/e-learning?authSource=admin
# URI=mongodb://<mongo-user>:<mongo-password>@<replica-host>:27017/e-learning?authSource=admin&replicaSet=<production-replica-set>
